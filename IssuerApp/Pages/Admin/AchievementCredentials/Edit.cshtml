@page
@using IssuerApp.Pages.Shared
@using IssuerApp.Pages.Admin.AchievementCredentials
@model EditModel

@{
    ViewData["Title"] = "Edit Open Badge";
    ViewData["ActivePage"] = NavPages.AchievementCredentials;
}

@if (!string.IsNullOrEmpty(ViewData["Message"]?.ToString()))
{
    <div class="alert alert-success">
        @ViewData["Message"]
    </div>
}

@if (!ModelState.IsValid)
{
    <div class="alert alert-danger">
        <div asp-validation-summary="All" class="text-danger"></div>
    </div>
}

<form method="post" class="card" enctype="multipart/form-data">
    <input type="hidden" asp-for="AchievementCredential.AchievementCredentialKey" />
    <input type="hidden" asp-for="AchievementCredential.CredentialSubject.AchievementSubjectKey" />
    <input type="hidden" asp-for="AchievementCredential.Id" />

    <div class="card-header d-flex align-items-center shadow">
        <div class="text-size-large me-auto">
            Edit Open Badge
        </div>
        <button asp-page-handler="" type="submit" class="btn btn-sm btn-dark mx-3 text-nowrap">
            <i class="fas fa-save"></i>
            <span class="d-none d-lg-inline text-uppercase">Save</span>
        </button>
        <partial name="AchievementCredentials/_DeleteButtonPartial" model="Model" />
    </div>

    <div class="card-body">
        <div class="row">
            <div class="col-xl-4">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="AchievementCredential.CredentialSubject.Achievement" class="input-group-text"></label>
                        <input class="form-control" type="text" readonly disabled value="@(Model.Achievement?.DisplayName)" />
                        <span class="input-group-text">
                            <description asp-for="AchievementCredential.CredentialSubject.Achievement"></description>
                        </span>
                    </div>
                </div>
            </div>
            <div class="col-xl-4">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="AchievementCredential.CredentialSubject.Member" class="input-group-text"></label>
                        <input class="form-control" type="text" readonly disabled value="@(Model.Member?.Name)" />
                        <span class="input-group-text">
                            <description asp-for="AchievementCredential.CredentialSubject.Member"></description>
                        </span>
                    </div>
                </div>
            </div>
            <div class="col-xl-4">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="AchievementCredential.ValidFrom" class="input-group-text"></label>
                        <input asp-for="AchievementCredential.ValidFrom" class="form-control" type="date" />
                        <span class="input-group-text">
                            <description asp-for="AchievementCredential.ValidFrom"></description>
                        </span>
                    </div>
                    <span asp-validation-for="AchievementCredential.ValidFrom"></span>
                </div>
            </div>
        </div>

        <h5 class="section-title">Wallet Display</h5>

        <div class="row">
            <div class="col-xl-4">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="AchievementCredential.Name" class="input-group-text"></label>
                        <input asp-for="AchievementCredential.Name" class="form-control" />
                        <span class="input-group-text">
                            <description asp-for="AchievementCredential.Name"></description>
                        </span>
                    </div>
                    <span asp-validation-for="AchievementCredential.Name"></span>
                </div>
            </div>
            <div class="col-xl-8">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="ImageId" class="input-group-text"></label>
                        @if (!string.IsNullOrEmpty(Model.ImageId))
                        {
                            <div class="input-group-text">
                                @if (Model.ImageId.StartsWith("data:"))
                                {
                                    <a href="#" onclick="exportToView('@Model.ImageId')">Preview</a>
                                }
                                else
                                {
                                    <a href="@Model.ImageId" target="_blank">Preview</a>
                                }
                            </div>
                        }
                        <input asp-for="ImageId" class="form-control" placeholder="Enter URL or upload file" />
                        <button type="button" class="btn btn-dark" data-bs-toggle="modal" data-bs-target="#upload">Upload Image</button>
                        <div class="input-group-text">
                            <description asp-for="ImageId"></description>
                        </div>
                    </div>
                    <span asp-validation-for="ImageId" class="text-danger"></span>
                </div>

                <div class="modal fade" id="upload" tabindex="-1" aria-labelledby="uploadLabel" aria-hidden="true">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title" id="uploadLabel">Upload Image File</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <div class="mb-3">
                                    <label asp-for="ImageFile" class="form-label">Choose an image that represents the credential</label>
                                    <input asp-for="ImageFile" type="file" class="form-control" accept="image/png,image/jpeg,image/gif,image/svg+xml" />
                                    <span asp-validation-for="ImageFile" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button id="upload-image-btn" type="submit" class="btn btn-dark" disabled
                                        asp-page-handler="UploadImage">
                                    Upload Image
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-12">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="AchievementCredential.Description" class="input-group-text"></label>
                        <textarea asp-for="AchievementCredential.Description" class="form-control"></textarea>
                        <span class="input-group-text">
                            <description asp-for="AchievementCredential.Description"></description>
                        </span>
                    </div>
                    <span asp-validation-for="AchievementCredential.Description" class="text-danger"></span>
                </div>
            </div>
        </div>

        <h5 class="section-title">Optional Details</h5>

        <div class="row">
            <div class="col-xl-4">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="AchievementCredential.ValidUntil" class="input-group-text"></label>
                        <input asp-for="AchievementCredential.ValidUntil" class="form-control" type="date" />
                        <span class="input-group-text">
                            <description asp-for="AchievementCredential.ValidUntil"></description>
                        </span>
                    </div>
                    <span asp-validation-for="AchievementCredential.ValidUntil"></span>
                </div>
            </div>
            <div class="col-xl-4">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="AchievementCredential.AwardedDate" class="input-group-text">Awarded Date</label>
                        <input asp-for="AchievementCredential.AwardedDate" class="form-control" type="date" />
                        <span class="input-group-text">
                            <description asp-for="AchievementCredential.AwardedDate"></description>
                        </span>
                    </div>
                    <span asp-validation-for="AchievementCredential.AwardedDate"></span>
                </div>
            </div>
            <div class="col-xl-4">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="AchievementCredential.CredentialSubject.Term" class="input-group-text"></label>
                        <input asp-for="AchievementCredential.CredentialSubject.Term" class="form-control" />
                        <span class="input-group-text">
                            <description asp-for="AchievementCredential.CredentialSubject.Term"></description>
                        </span>
                    </div>
                    <span asp-validation-for="AchievementCredential.CredentialSubject.Term"></span>
                </div>
            </div>
            <div class="col-xl-4">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="AchievementCredential.CredentialSubject.ActivityStartDate" class="input-group-text"></label>
                        <input asp-for="AchievementCredential.CredentialSubject.ActivityStartDate" class="form-control" type="date" />
                        <span class="input-group-text">
                            <description asp-for="AchievementCredential.CredentialSubject.ActivityStartDate"></description>
                        </span>
                    </div>
                    <span asp-validation-for="AchievementCredential.CredentialSubject.ActivityStartDate"></span>
                </div>
            </div>
            <div class="col-xl-4">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="AchievementCredential.CredentialSubject.ActivityEndDate" class="input-group-text"></label>
                        <input asp-for="AchievementCredential.CredentialSubject.ActivityEndDate" class="form-control" type="date" />
                        <span class="input-group-text">
                            <description asp-for="AchievementCredential.CredentialSubject.ActivityEndDate"></description>
                        </span>
                    </div>
                    <span asp-validation-for="AchievementCredential.CredentialSubject.ActivityEndDate"></span>
                </div>
            </div>
            <div class="col-xl-4">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="AchievementCredential.CredentialSubject.Role" class="input-group-text"></label>
                        <input asp-for="AchievementCredential.CredentialSubject.Role" class="form-control" />
                        <span class="input-group-text">
                            <description asp-for="AchievementCredential.CredentialSubject.Role"></description>
                        </span>
                    </div>
                    <span asp-validation-for="AchievementCredential.CredentialSubject.Role"></span>
                </div>
            </div>
            <div class="col-xl-4">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="AchievementCredential.CredentialSubject.CreditsEarned" class="input-group-text"></label>
                        <input asp-for="AchievementCredential.CredentialSubject.CreditsEarned" class="form-control" />
                        <span class="input-group-text">
                            <description asp-for="AchievementCredential.CredentialSubject.CreditsEarned"></description>
                        </span>
                    </div>
                    <span asp-validation-for="AchievementCredential.CredentialSubject.CreditsEarned"></span>
                </div>
            </div>
            <div class="col-xl-4">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="AchievementCredential.CredentialSubject.LicenseNumber" class="input-group-text"></label>
                        <input asp-for="AchievementCredential.CredentialSubject.LicenseNumber" class="form-control" />
                        <span class="input-group-text">
                            <description asp-for="AchievementCredential.CredentialSubject.LicenseNumber"></description>
                        </span>
                    </div>
                    <span asp-validation-for="AchievementCredential.CredentialSubject.LicenseNumber"></span>
                </div>
            </div>
            <div class="col-xl-4">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="SourceKey" class="input-group-text">Source</label>
                        <select class="form-select"
                                asp-for="SourceKey"
                                asp-items="Model.Organizations">
                            <option value="">Select an organization</option>
                        </select>
                        <span class="input-group-text">
                            <description asp-for="AchievementCredential.CredentialSubject.Source"></description>
                        </span>
                    </div>
                    <span asp-validation-for="SourceKey"></span>
                </div>
            </div>
            <div class="col-xl-12">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="AchievementCredential.CredentialSubject.Narrative" class="input-group-text"></label>
                        <textarea asp-for="AchievementCredential.CredentialSubject.Narrative" class="form-control" placeholder="(markdown allowed)"></textarea>
                        <span class="input-group-text">
                            <description asp-for="AchievementCredential.CredentialSubject.Narrative"></description>
                        </span>
                    </div>
                    <span asp-validation-for="AchievementCredential.CredentialSubject.Narrative" class="text-danger"></span>
                </div>
            </div>
        </div>
    </div>
</form>

@* ── Credential Status (VC 2.0 §5.9 / Bitstring Status List) ───────────────── *@
<div class="card mt-4">
    <div class="card-header d-flex align-items-center">
        @if (Model.StatusListIndex.HasValue)
        {
            if (Model.IsRevoked)
            {
                <span class="badge bg-danger me-2">Revoked</span>
            }
            else
            {
                <span class="badge bg-success me-2">Active</span>
            }
        }
        else
        {
            <span class="badge bg-secondary me-2">Not yet issued</span>
        }
        <span class="me-auto fw-semibold">Credential Status</span>
    </div>
    <div class="card-body">
        @if (Model.StatusListIndex.HasValue)
        {
            <dl class="row mb-2">
                <dt class="col-sm-3">Status list index</dt>
                <dd class="col-sm-9 font-monospace">@Model.StatusListIndex</dd>

                <dt class="col-sm-3">Status list credential</dt>
                <dd class="col-sm-9">
                    <a href="@Model.StatusListCredentialUrl" target="_blank" class="font-monospace small">
                        @Model.StatusListCredentialUrl
                    </a>
                </dd>

                <dt class="col-sm-3">credentialStatus.type</dt>
                <dd class="col-sm-9 font-monospace">BitstringStatusListEntry</dd>
            </dl>

            <p class="text-muted small mb-3">
                Revoking a credential flips its bit in the Bitstring Status List instantly.
                The wallet does <em>not</em> need to be notified — verifiers fetch the live
                status list every time they verify a credential.
                Re-issuing the credential (having the student receive it again) will deliver
                the current <code>credentialStatus</code> pointer embedded in the signed JSON.
            </p>

            <div class="d-flex gap-2">
                @if (Model.IsRevoked)
                {
                    <form method="post" asp-page-handler="Activate" asp-route-key="@Model.AchievementCredential.AchievementCredentialKey">
                        <button type="submit" class="btn btn-success btn-sm">
                            <i class="fas fa-check-circle me-1"></i> Re-activate credential
                        </button>
                    </form>
                }
                else
                {
                    <form method="post" asp-page-handler="Revoke" asp-route-key="@Model.AchievementCredential.AchievementCredentialKey">
                        <button type="submit" class="btn btn-danger btn-sm"
                                onclick="return confirm('Are you sure you want to revoke this credential? Verifiers will immediately see it as revoked.')">
                            <i class="fas fa-ban me-1"></i> Revoke credential
                        </button>
                    </form>
                }
                <a asp-page="./Issue" asp-route-key="@Model.AchievementCredential.AchievementCredentialKey"
                   class="btn btn-outline-primary btn-sm">
                    <i class="fas fa-redo me-1"></i> Re-issue (send updated credential to wallet)
                </a>
            </div>
        }
        else
        {
            <p class="text-muted mb-2">
                A <code>credentialStatus</code> entry will be automatically embedded the first time
                this credential is issued to a wallet via the <strong>Issue via VCALM</strong> page.
            </p>
            <a asp-page="./Issue" asp-route-key="@Model.AchievementCredential.AchievementCredentialKey"
               class="btn btn-outline-primary btn-sm">
                <i class="fas fa-file-export me-1"></i> Issue this credential
            </a>
        }
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_DisplayScriptsPartial");
    }
    <script>
        $('#ImageFile').change(function () {
            $('#upload-image-btn')[0].disabled = $('#ImageFile')[0].files.length === 0;
        });
    </script>
}

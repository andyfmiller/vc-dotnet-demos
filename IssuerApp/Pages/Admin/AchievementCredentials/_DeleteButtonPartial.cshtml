@model EditModel

<button type="button" class="btn btn-sm btn-dark text-nowrap" data-bs-toggle="modal" data-bs-target="#deleteConfirmation">
    <i class="fas fa-trash-alt"></i>
    <span class="d-none d-lg-inline text-uppercase">Delete</span>
</button>
<div class="modal fade" id="deleteConfirmation" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete @(string.IsNullOrEmpty(Model.AchievementCredential.Name) ? Model.AchievementCredential.CredentialSubject?.Achievement?.DisplayName : Model.AchievementCredential.Name)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p>
                    Are you sure you want to delete this Open Badge?
                </p>
                <button type="submit" class="btn btn-sm btn-danger text-uppercase"
                        asp-page-handler="DeleteAchievementCredential" asp-route-key="@Model.AchievementCredential.AchievementCredentialKey"
                        asp-route-pagename="Index">
                    Delete
                </button>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-secondary text-uppercase" data-bs-dismiss="modal">
                    Cancel
                </button>
            </div>
        </div>
    </div>
</div>

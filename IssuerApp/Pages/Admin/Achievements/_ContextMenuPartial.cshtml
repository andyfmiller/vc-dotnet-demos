@using IssuerApp.Data.Models.OpenBadges
@model Achievement

@* This context menu is used by the admin dashboard *@

<div class="dropdown">
    <button class="btn btn-sm text-muted" type="button" data-bs-toggle="dropdown" aria-expanded="false">
        <i class="fas fa-ellipsis-v"></i>
    </button>
    <ul class="dropdown-menu dropdown-menu-end">
        <li>
            <a asp-page="/Admin/Achievements/Edit"
               asp-route-key="@Model.AchievementKey"
               class="dropdown-item">
                <i class="fas fa-edit me-1" style="width: 1em"></i>
                View / Edit
            </a>
        </li>
        <li>
            <a asp-page="/Admin/AchievementCredentials/Create"
               asp-route-achievementKey="@Model.AchievementKey"
               class="dropdown-item">
                <i class="far fa-id-card me-1" style="width: 1em"></i>
                Issue Credential
            </a>
        </li>
        <li>
            <a href="#"
               class="dropdown-item"
               data-bs-toggle="modal"
               data-bs-target="#@($"delete-achievement-{Model.AchievementKey}")">
                <i class="fas fa-trash-alt me-1" style="width: 1em"></i>
                Delete
            </a>
        </li>
    </ul>
</div>
<form method="post"
      class="modal"
      id="@($"delete-achievement-{Model.AchievementKey}")"
      tabindex="-1"
      data-ajax="true"
      data-ajax-method="post"
      data-ajax-url="?handler=DeleteAchievement&amp;key=@Model.AchievementKey"
      data-ajax-loading="#loader"
      data-ajax-success="$('#delete-achievement-@Model.AchievementKey').one('hidden.bs.modal', function(){ $('#achievement-@Model.AchievementKey').remove(); }).modal('hide');"
      data-ajax-failure="showToast(xhr.statusText">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete @Model.Name</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>
                    Are you sure you want to delete this achievement? This will
                    also delete all assertions of this achievement.
                </p>
                <button type="submit" class="btn btn-sm btn-danger text-uppercase">
                    Delete
                </button>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-secondary text-uppercase"
                        data-bs-dismiss="modal">
                    Cancel
                </button>
            </div>
        </div>
    </div>
</form>
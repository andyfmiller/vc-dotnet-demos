@page
@using IssuerApp.Data
@using IssuerApp.Data.Models
@using IssuerApp.Pages.Shared
@using IssuerApp.Pages.Admin.Organizations
@using Microsoft.EntityFrameworkCore
@model EditModel

@{
    ViewData["Title"] = "Edit Organization";
    ViewData["ActivePage"] = NavPages.Organizations;
}

@if (!string.IsNullOrEmpty(ViewData["Message"]?.ToString()))
{
    <div class="alert alert-success">
        @ViewData["Message"]
    </div>
}

@if (!ModelState.IsValid)
{
    <div class="alert alert-danger">
        <div asp-validation-summary="All" class="text-danger"></div>
    </div>
}

<form method="post" enctype="multipart/form-data" class="card shadow mt-3">
    <input type="hidden" asp-for="Organization.OrganizationKey" />
    <input type="hidden" asp-for="Organization.Profile.ProfileKey" />
    <input type="hidden" asp-for="Organization.Profile.Id" />
    <input type="hidden" asp-for="Organization.Profile.Address.AddressKey" />
    <input type="hidden" asp-for="Organization.Profile.Image.ImageKey" />
    <div class="card-header d-flex align-items-center shadow">
        <div class="text-size-large me-auto">
            Edit Organization
        </div>
        <button type="submit" asp-page-handler="" class="btn btn-sm btn-dark mx-3 text-nowrap">
            <i class="fas fa-save"></i>
            <span class="d-none d-sm-inline text-uppercase">Save</span>
        </button>
        <partial name="Organizations/_DeleteButtonPartial" model="Model.Organization" />
    </div>

    <div class="card-body">

        @* // Required Details *@

        <div class="row">
            <div class="col-xl-4">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="Organization.Profile.Id" class="input-group-text"></label>
                        <input asp-for="Organization.Profile.Id" readonly="readonly" class="form-control" data-lpignore="true" />
                        <span class="input-group-text">
                            <description asp-for="Organization.Profile.Id">
                                READONLY. The value of the Organization's Id is a URL that identifies the Organization in a globally unambiguous way using a did:web identifier.
                            </description>
                        </span>
                    </div>
                    <span asp-validation-for="Organization.Profile.Id"></span>
                </div>
            </div>
        </div>

        <h5 class="section-title">Optional Details</h5>

        <div class="row">
            <div class="col-xl-4">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="Organization.Profile.Name" class="input-group-text"></label>
                        <input asp-for="Organization.Profile.Name" class="form-control" />
                        <span class="input-group-text">
                            <description asp-for="Organization.Profile.Name">
                                The full name of the organization.
                            </description>
                        </span>
                    </div>
                    <span asp-validation-for="Organization.Profile.Name"></span>
                </div>
            </div>
            <div class="col-xl-8">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="ImageId" class="input-group-text"></label>
                        @if (!string.IsNullOrEmpty(Model.ImageId))
                        {
                            <div class="input-group-text">
                                @if (Model.ImageId.StartsWith("data:"))
                                {
                                    <a href="#" onclick="exportToView('@Model.ImageId')">Preview</a>
                                }
                                else
                                {
                                    <a href="@Model.ImageId" target="_blank">Preview</a>
                                }
                            </div>
                        }
                        <input asp-for="ImageId" class="form-control" placeholder="Enter URL or upload file" />
                        <button type="button" class="btn btn-dark" data-bs-toggle="modal" data-bs-target="#upload">Upload Image</button>
                        <div class="input-group-text">
                            <description asp-for="ImageId">
                                An image representing the organization.
                            </description>
                        </div>
                    </div>
                    <span asp-validation-for="ImageId" class="text-danger"></span>
                </div>

                <div class="modal fade" id="upload" tabindex="-1" aria-labelledby="uploadLabel" aria-hidden="true">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title" id="uploadLabel">Upload Image File</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <input type="hidden" asp-for="Organization.OrganizationKey" />
                                <div class="mb-3">
                                    <label asp-for="ImageFile" class="form-label">Choose an image that represents the organization</label>
                                    <input asp-for="ImageFile" type="file" class="form-control" accept="image/png,image/jpeg,image/gif,image/svg+xml" />
                                    <span asp-validation-for="ImageFile" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button id="upload-image-btn" type="submit" class="btn btn-dark" disabled
                                        asp-page-handler="UploadImage">
                                    Upload Image
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-4">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="Organization.Profile.Url" class="input-group-text">Website</label>
                        <input type="text" asp-for="Organization.Profile.Url" class="form-control" />
                        <span class="input-group-text">
                            <description asp-for="Organization.Profile.Url">
                                The organization's website URL
                            </description>
                        </span>
                    </div>
                    <span asp-validation-for="Organization.Profile.Url"></span>
                </div>
            </div>
        </div>

        <h5 class="section-title">Contact Information</h5>

        <div class="row">
            <div class="col-xl-4">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="Organization.Profile.Official" class="input-group-text"></label>
                        <input type="text" asp-for="Organization.Profile.Official"
                               class="form-control"
                               data-lpignore="true" />
                        <span class="input-group-text">
                            <description asp-for="Organization.Profile.Official">
                                The name of the authorized official for the organization.
                            </description>
                        </span>
                    </div>
                    <span asp-validation-for="Organization.Profile.Official"></span>
                </div>
            </div>
            <div class="col-xl-8">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="Organization.Profile.Address.StreetAddress" class="input-group-text">Street Address</label>
                        <input type="text" asp-for="Organization.Profile.Address.StreetAddress" class="form-control" />
                        <span class="input-group-text">
                            <description asp-for="Organization.Profile.Address.StreetAddress"></description>
                        </span>
                    </div>
                    <span asp-validation-for="Organization.Profile.Address.StreetAddress"></span>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-xl-4">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="Organization.Profile.Address.AddressLocality" class="input-group-text">Locality</label>
                        <input type="text" asp-for="Organization.Profile.Address.AddressLocality"
                               class="form-control"
                               data-lpignore="true" />
                        <span class="input-group-text">
                            <description asp-for="Organization.Profile.Address.AddressLocality"></description>
                        </span>
                    </div>
                    <span asp-validation-for="Organization.Profile.Address.AddressLocality"></span>
                </div>
            </div>
            <div class="col-xl-4">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="Organization.Profile.Address.AddressRegion" class="input-group-text">Region</label>
                        <input type="text" asp-for="Organization.Profile.Address.AddressRegion" class="form-control" />
                        <span class="input-group-text">
                            <description asp-for="Organization.Profile.Address.AddressRegion"></description>
                        </span>
                    </div>
                    <span asp-validation-for="Organization.Profile.Address.AddressRegion"></span>
                </div>
            </div>
            <div class="col-xl-4">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="Organization.Profile.Address.PostalCode" class="input-group-text">Postal Code</label>
                        <input type="text" asp-for="Organization.Profile.Address.PostalCode" class="form-control" />
                        <span class="input-group-text">
                            <description asp-for="Organization.Profile.Address.PostalCode"></description>
                        </span>
                    </div>
                    <span asp-validation-for="Organization.Profile.Address.PostalCode"></span>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-xl-4">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="Organization.Profile.Address.AddressCountry" class="input-group-text">Country</label>
                        <input type="text" asp-for="Organization.Profile.Address.AddressCountry" class="form-control" />
                        <span class="input-group-text">
                            <description asp-for="Organization.Profile.Address.AddressCountry"></description>
                        </span>
                    </div>
                    <span asp-validation-for="Organization.Profile.Address.AddressCountry"></span>
                </div>
            </div>
            <div class="col-xl-4">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="Organization.Profile.Phone" class="input-group-text"></label>
                        <input type="text" asp-for="Organization.Profile.Phone" class="form-control" />
                        <span class="input-group-text">
                            <description asp-for="Organization.Profile.Phone">
                                Primary phone number for the organization.
                            </description>
                        </span>
                    </div>
                    <span asp-validation-for="Organization.Profile.Phone"></span>
                </div>
            </div>
            <div class="col-xl-4">
                <div class="mb-2">
                    <div class="input-group input-group-sm">
                        <label asp-for="Organization.Profile.Email" class="input-group-text"></label>
                        <input type="email" asp-for="Organization.Profile.Email" class="form-control" />
                        <span class="input-group-text">
                            <description asp-for="Organization.Profile.Email">
                                The contact email address for the organization.
                            </description>
                        </span>
                    </div>
                    <span asp-validation-for="Organization.Profile.Email"></span>
                </div>
            </div>
        </div>
    </div>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_DisplayScriptsPartial");
    }
    <script>
        // Enable/disable upload button based on file selection
        document.getElementById('ImageFile').addEventListener('change', function() {
            const uploadBtn = document.getElementById('upload-image-btn');
            uploadBtn.disabled = this.files.length === 0;
        });

        // Close modal after successful upload
        // Check if the form was posted with UploadImage handler and has no validation errors
        const imageIdInput = document.querySelector('input[name="ImageId"]');
        const uploadModal = document.getElementById('upload');

        if (imageIdInput && uploadModal && '@TempData["ImageUploaded"]' === 'true') {
            // Close the modal using Bootstrap's modal API
            const modal = bootstrap.Modal.getInstance(uploadModal);
            if (modal) {
                modal.hide();
            }
            // Clear the file input
            document.getElementById('ImageFile').value = '';
        }
    </script>
}
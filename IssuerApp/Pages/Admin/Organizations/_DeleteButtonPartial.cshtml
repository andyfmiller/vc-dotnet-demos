@using IssuerApp.Data.Models
@model Organization

<button type="button" class="btn btn-sm btn-dark" data-bs-toggle="modal" data-bs-target="#deleteConfirmation">
    <i class="fas fa-trash-alt"></i>
    <span class="d-none d-sm-inline text-uppercase">Delete</span>
</button>
<div class="modal fade" id="deleteConfirmation" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete @Model.Profile?.Name</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>
                    Are you sure you want to delete this organization? This will also delete
                    its members, achievements, and issued credentials.
                </p>
                <button type="submit" asp-page-handler="DeleteOrganization" asp-route-key="@Model.OrganizationKey"
                        asp-route-pagename="Index" class="btn btn-sm btn-danger text-uppercase">
                    Delete
                </button>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-secondary text-uppercase" data-bs-dismiss="modal">
                    Cancel
                </button>
            </div>
        </div>
    </div>
</div>

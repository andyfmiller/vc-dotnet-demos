@page
@using IssuerApp.Pages.Shared
@model IssueModel

@{
    ViewData["Title"] = "Request Credential";
    ViewData["ActivePage"] = NavPages.Dashboard;
}

<h2 class="mt-3">Request Credential</h2>
<p class="text-muted">
    Review your credential below and click <strong>Request Credential</strong>
    to initiate issuance. An Interaction URL (§3.7.1) will be generated that you can open in your wallet.
    Your wallet will prove DID ownership during the exchange.
</p>

@if (Model.AchievementCredential is not null)
{
    <div class="card shadow mb-3">
        <div class="card-header d-flex align-items-center shadow">
            <div class="card-header-icon">
                <i class="fa-regular fa-id-card" style="font-size: 2em"></i>
            </div>
            <div class="text-size-large ms-2 me-auto">
                Credential Details
            </div>
            @if (Model.InteractionUrl is null)
            {
                <form method="post" asp-page-handler="Request" asp-route-key="@Model.AchievementCredential.AchievementCredentialKey">
                    <button type="submit" class="btn btn-sm btn-dark me-2" title="Request Credential" data-bs-toggle="tooltip">
                        <i class="fa-regular fa-hand"></i>
                        <span class="d-none d-lg-inline text-uppercase">Request Credential</span>
                    </button>
                </form>
            }
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                @if (Model.AchievementCredential.Name is not null)
                {
                    <dt class="col-sm-3">Name</dt>
                    <dd class="col-sm-9">@Model.AchievementCredential.Name</dd>
                }
                @if (Model.AchievementCredential.Description is not null)
                {
                    <dt class="col-sm-3">Description</dt>
                    <dd class="col-sm-9">@Model.AchievementCredential.Description</dd>
                }
                <dt class="col-sm-3">Achievement</dt>
                <dd class="col-sm-9">@(Model.Achievement?.Name ?? "n/a")</dd>

                <dt class="col-sm-3">Issuer</dt>
                <dd class="col-sm-9">@(Model.IssuerName ?? "n/a")</dd>

                <dt class="col-sm-3">Valid From</dt>
                <dd class="col-sm-9">@Html.DisplayFor(x => Model.AchievementCredential!.ValidFrom)</dd>

                @if (Model.AchievementCredential.ValidUntil is not null)
                {
                    <dt class="col-sm-3">Valid Until</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(x => Model.AchievementCredential!.ValidUntil)</dd>
                }
            </dl>
        </div>
    </div>
}

@if (Model.InteractionUrl is not null)
{
    <div class="alert alert-success">
        <h5 class="alert-heading">Interaction URL generated</h5>
        <p>
            Scan the QR code below with your wallet, or open the URL in your wallet to receive the credential.
        </p>
        <div class="mb-3 d-flex justify-content-center">
            <div id="interactionQrCode"></div>
        </div>
        <div class="input-group mb-2">
            <input id="interactionUrl"
                   type="text"
                   class="form-control font-monospace"
                   value="@Model.InteractionUrl"
                   readonly />
            <button class="btn btn-outline-secondary"
                    type="button"
                    onclick="navigator.clipboard.writeText(document.getElementById('interactionUrl').value)">
                Copy
            </button>
        </div>
    </div>
}

@section Scripts {
    @if (Model.InteractionUrl is not null)
    {
        <script src="~/lib/qrcodejs/qrcode.min.js"></script>
        <script>
            new QRCode(document.getElementById("interactionQrCode"), {
                text: "@Html.Raw(Model.InteractionUrl)",
                width: 128,
                height: 128,
                correctLevel: QRCode.CorrectLevel.M
            });
        </script>
    }
}

@using IssuerApp
@using IssuerApp.Data
@using IssuerApp.Data.Models
@using IssuerApp.Extensions
@using Microsoft.AspNetCore.Identity

@inject ApplicationDbContext _dbContext
@inject UserManager<ApplicationUser> _userManager


@if (User.Identity is { IsAuthenticated: true })
{
    var path = $"{Context.Request.PathBase}{Context.Request.Path}";
    var query = Context.Request.QueryString;
    query = query.Add("handler", "ChangeRole");
    var user = await _userManager.GetUserAsync(User);
    var role = user != null ? await user.GetUserRole(_userManager) : null;

    <li class="nav-item">
        <div class="dropdown nav-link d-flex align-items-center gap-2">
            <i class="fa-solid fa-hat-cowboy" style="font-size: 1.5em" data-bs-toggle="tooltip" title="Change Your Demo Role"></i>
            <div class="dropdown-toggle"
                   href="#"
                   id="roleSelectorDropdown"
                   role="button"
                   data-bs-toggle="dropdown"
                   aria-haspopup="true"
                   aria-expanded="false">
                @role
            </div>

            <form class="dropdown-menu"
                  method="post"
                  action="@(path)@(query.ToUriComponent())"
                  aria-labelledby="roleSelectorDropdown">

                <h6 class="dropdown-header">Role</h6>
                <div class="dropdown-divider"></div>

                @foreach (var userRole in Constants.Roles.UserRoles.OrderBy(x => x))
                {
                    <button type="submit"
                            class="dropdown-item" @(userRole == role ? "disabled" : "")
                            name="NavRole"
                            value="@userRole">
                        @userRole
                    </button>
                }
            </form>
        </div>
    </li>
}
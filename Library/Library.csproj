<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <SkipVcalmClient>false</SkipVcalmClient>
        <SkipOpenBadgesClient>false</SkipOpenBadgesClient>
    </PropertyGroup>
    
    <!-- Suppress NuGet vulnerability warnings -->
    <ItemGroup>
        <NuGetAuditSuppress Include="https://github.com/advisories/GHSA-g4vj-cjjj-v7hg" />
    </ItemGroup>
    
    <ItemGroup>
        <EmbeddedResource Include="JsonLdContexts\*.json" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="dotNetRdf.Core" Version="3.5.1" />
        <PackageReference Include="Microsoft.IdentityModel.JsonWebTokens" Version="8.18.0" />
        <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
        <PackageReference Include="NSec.Cryptography" Version="26.4.0" />
        <PackageReference Include="Serilog" Version="4.3.1" />
        <!-- Kiota runtime packages for the VCALM generated client -->
        <PackageReference Include="Microsoft.Kiota.Abstractions" Version="2.0.0" />
        <PackageReference Include="Microsoft.Kiota.Http.HttpClientLibrary" Version="2.0.0" />
        <PackageReference Include="Microsoft.Kiota.Serialization.Json" Version="2.0.0" />
        <PackageReference Include="Microsoft.Kiota.Serialization.Text" Version="2.0.0" />
        <PackageReference Include="Microsoft.Kiota.Serialization.Form" Version="2.0.0" />
        <PackageReference Include="Microsoft.Kiota.Serialization.Multipart" Version="2.0.0" />
    </ItemGroup>

    <Target Name="CleanGeneratedFiles" AfterTargets="Clean">
        <ItemGroup>
            <OpenBadgesGeneratedFiles Include="$(ProjectDir)OpenBadges\Generated\**\*" />
            <VcalmGeneratedFiles Include="$(ProjectDir)Vcalm\Generated\**\*" />
        </ItemGroup>

        <Delete Files="@(OpenBadgesGeneratedFiles)" />
        <Delete Files="@(VcalmGeneratedFiles)" />
    </Target>
    
    <!-- Generate VCALM API client on build (Kiota) -->
    <Target Name="GenerateVcalmClient" Condition="'$(SkipVcalmClient)' != 'true'" BeforeTargets="CoreCompile" Inputs="Vcalm\oas.yaml" Outputs="Vcalm\Generated\VcalmClient.cs">

        <Message Importance="high" Text="Generating VCALM API client from OpenAPI spec (Kiota)..." />

        <!-- Delete Kiota's lock file so it does not skip generation.
             MSBuild's Inputs/Outputs already handles incremental detection. -->
        <Delete Files="$(MSBuildProjectDirectory)/Vcalm/Generated/kiota-lock.json" ContinueOnError="true" />

        <Exec Command="kiota generate -l CSharp -d &quot;oas.yaml&quot; -o &quot;$(MSBuildProjectDirectory)/Vcalm/Generated&quot; -n Library.Vcalm.Client -c VcalmClient --structured-mime-types application/json" ConsoleToMSBuild="true" ContinueOnError="true" WorkingDirectory="$(MSBuildProjectDirectory)/Vcalm" />
        <Error Condition="!Exists('$(MSBuildProjectDirectory)/Vcalm/Generated/VcalmClient.cs')" Text="Kiota generation failed: VcalmClient.cs was not generated." />
    </Target>

    <!-- Generate OpenBadges API client on build (Kiota) -->
    <Target Name="GenerateOpenBadgesClient" Condition="'$(SkipOpenBadgesClient)' != 'true'" BeforeTargets="CoreCompile" DependsOnTargets="GenerateVcalmClient" Inputs="OpenBadges\ob_v3p0_oas.json" Outputs="OpenBadges\Generated\OpenBadgesClient.cs">

        <Message Importance="high" Text="Generating OpenBadges API client from OpenAPI spec (Kiota)..." />

        <!-- Delete Kiota's lock file so it does not skip generation.
             MSBuild's Inputs/Outputs already handles incremental detection. -->
        <Delete Files="$(MSBuildProjectDirectory)/OpenBadges/Generated/kiota-lock.json" ContinueOnError="true" />

        <Exec Command="kiota generate -l CSharp -d &quot;ob_v3p0_oas.json&quot; -o &quot;$(MSBuildProjectDirectory)/OpenBadges/Generated&quot; -n Library.OpenBadges.Client -c OpenBadgesClient --structured-mime-types application/json" ConsoleToMSBuild="true" ContinueOnError="true" WorkingDirectory="$(MSBuildProjectDirectory)/OpenBadges" />
        <Error Condition="!Exists('$(MSBuildProjectDirectory)/OpenBadges/Generated/OpenBadgesClient.cs')" Text="Kiota generation failed: OpenBadgesClient.cs was not generated." />
    </Target>
</Project>
@page
@using System.Text.Json
@using System.Text.Json.Nodes
@using WalletApp.Pages.Shared
@model WalletApp.Pages.Holder.DetailModel

@{
    ViewData["Title"] = "Credential Details";
    ViewData["ActivePage"] = NavPages.MyCredentials;
    var vc = Model.VerifiableCredential;
}

@if (vc is not null)
{
    <div class="card shadow mt-3">
        <div class="card-header d-flex align-items-center shadow">
            <div class="card-header-icon me-2">
                <i class="fa-regular fa-id-card" style="font-size: 2em"></i>
            </div>
            <div class="text-size-large me-auto">
                Credential Details
            </div>
        </div>
        <div class="card-body">

            @if (Model.HtmlRender is not null)
            {
                @* ── W3C VC Rendering Methods §html render suite: host page ─────────────
                   The spec requires:
                     • an <iframe sandbox="allow-scripts"> whose content is set via srcdoc
                     • wrapper code that embeds the (filtered) VC in a
                       <script type="application/vc"> data block inside <head>
                     • the template fragment in <body>
                     • a MessageChannel between host page and iframe for "ready"/"error"
                       signalling so the host page knows when rendering is complete.
                   The CSP header on the wrapper doc prevents any network requests from
                   the template (default-src data: 'unsafe-inline').
                ──────────────────────────────────────────────────────────────────────── *@

                <iframe id="vc-render-frame"
                        sandbox="allow-scripts"
                        style="width:100%;border:none;min-height:200px;"
                        title="Verifiable Credential Rendering"></iframe>

                @* Store template + VC data in hidden script tags so JS can read them
                   without any extra round-trips. *@
                <script id="vc-render-template" type="text/x-vc-template">
                    @Html.Raw(Model.HtmlRender.TemplateHtml)
                </script>
                <script id="vc-render-data" type="application/json">
                    @Html.Raw(Model.HtmlRender.VcJson)
                </script>

                <script>
                (function () {
                    const templateHtml = document.getElementById('vc-render-template').innerHTML;
                    const vcJson       = document.getElementById('vc-render-data').textContent;

                    // Build wrapper code per spec §Wrapper Code:
                    //   • CSP: default-src data: 'unsafe-inline'  (no network from template)
                    //   • <script type="application/vc"> data block in <head>
                    //   • MessageChannel plumbing (window.renderMethodReady)
                    //   • Template fragment in <body>
                    const wrapperCode = `<!DOCTYPE html>
<html>
<head>
<meta http-equiv="Content-Security-Policy"
      content="default-src data: 'unsafe-inline'">
<script type="application/vc">${vcJson.replace(/<\/script>/gi, '<\\/script>')}<\/script>
<script>
window.addEventListener('message', function (evt) {
    const port = evt.ports && evt.ports[0];
    if (!port) return;
    window.renderMethodReady = function (err) {
        if (err) { port.postMessage({ type: 'error', message: String(err) }); }
        else      { port.postMessage({ type: 'ready' }); }
    };
    // Auto-signal ready if the template does not call renderMethodReady itself.
    window.addEventListener('load', function () {
        if (!window._renderMethodReadyCalled) {
            port.postMessage({ type: 'ready' });
        }
    });
}, { once: true });
<\/script>
</head>
<body>
${templateHtml}
</body>
</html>`;

                    const iframe = document.getElementById('vc-render-frame');

                    // Set up MessageChannel before srcdoc so the onload handler is ready.
                    iframe.addEventListener('load', function () {
                        const channel = new MessageChannel();
                        channel.port1.onmessage = function (evt) {
                            if (evt.data && evt.data.type === 'ready') {
                                // Reveal iframe; resize to content if possible.
                                iframe.style.display = '';
                                try {
                                    const h = iframe.contentDocument &&
                                              iframe.contentDocument.body &&
                                              iframe.contentDocument.body.scrollHeight;
                                    if (h) iframe.style.minHeight = h + 'px';
                                } catch (_) { /* sandboxed – ignore */ }
                            } else if (evt.data && evt.data.type === 'error') {
                                console.error('VC render error:', evt.data.message);
                                showFallback();
                            }
                        };
                        iframe.contentWindow.postMessage('init', '*', [channel.port2]);
                    });

                    iframe.srcdoc = wrapperCode;

                    function showFallback() {
                        iframe.style.display = 'none';
                        document.getElementById('vc-property-tree').style.display = '';
                    }

                    // Safety net: if iframe never signals ready within 5 s, show fallback.
                    setTimeout(function () {
                        if (iframe.style.display !== 'none' && iframe.srcdoc) {
                            // still waiting – just leave iframe visible; template may not
                            // call renderMethodReady, which is allowed by the spec.
                        }
                    }, 5000);
                })();
                </script>

                <div id="vc-property-tree" style="display:none;">
                    @await Html.PartialAsync("_VcPropertyTree",
                        JsonNode.Parse(Model.CredentialJson)!)
                </div>
            }
            else
            {
                @* ── Fallback: recursive property tree ─────────────────────────────── *@
                @await Html.PartialAsync("_VcPropertyTree",
                    JsonNode.Parse(Model.CredentialJson)!)
            }

        </div>
    </div>

    @if (Model.ReplacedAt.HasValue)
    {
        <div class="card shadow mt-3">
            <div class="card-header d-flex align-items-center">
                <i class="fas fa-sync-alt me-2 text-warning"></i>
                <span class="me-auto">Credential updated on @Model.ReplacedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
            </div>
            <div class="card-body">
                @if (Model.CredentialChanges is { Count: > 0 })
                {
                    <p class="text-muted small mb-2">
                        The following properties changed when the issuer re-issued this credential.
                    </p>
                    <table class="table table-sm table-bordered mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Property</th>
                                <th class="text-danger">Previous value</th>
                                <th class="text-success">New value</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var change in Model.CredentialChanges)
                            {
                                <tr>
                                    <td class="font-monospace small">@change.PropertyPath</td>
                                    <td class="text-danger small">@(change.OldValue ?? "(none)")</td>
                                    <td class="text-success small">@(change.NewValue ?? "(none)")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted small mb-0">No leaf-property differences detected.</p>
                }
            </div>
        </div>
    }
}

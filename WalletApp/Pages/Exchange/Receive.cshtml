@page
@using WalletApp.Pages.Shared
@model ReceiveModel

@{
    ViewData["Title"] = "Receive Credential";
    ViewData["ActivePage"] = NavPages.MyCredentials;
}

@if (!string.IsNullOrEmpty(ViewData["Message"]?.ToString()))
{
    <div class="alert alert-success">
        @ViewData["Message"]
    </div>
}

<h2 class="mt-3">Receive Credential</h2>

<form method="post" id="receive-form">
    <div class="row g-3 mt-1 align-items-stretch">

        @* Option A: Enter URL *@
        <div class="col-12 col-md-6">
            <div class="card h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title"><i class="fas fa-link me-2"></i>Enter URL</h5>
                    <p class="card-text text-muted small">
                        Paste the Interaction URL shared by the issuing organization.
                    </p>
                    <div class="mt-auto">
                        <label asp-for="InteractionUrl" class="form-label visually-hidden"></label>
                        <input asp-for="InteractionUrl"
                               id="InteractionUrl"
                               type="url"
                               class="form-control font-monospace"
                               placeholder="https://issuer.example.com/interactions/abc123?iuv=1"
                               autofocus />
                        <span asp-validation-for="InteractionUrl" class="text-danger small"></span>
                        <button type="submit" class="btn btn-primary w-100 mt-3">
                            <i class="fas fa-download me-1"></i> Receive Credential
                        </button>
                    </div>
                </div>
            </div>
        </div>

        @* Option B: Scan QR *@
        <div class="col-12 col-md-6">
            <div class="card h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title"><i class="fas fa-qrcode me-2"></i>Scan QR Code</h5>
                    <p class="card-text text-muted small">
                        Point your camera at the QR code displayed by the issuer.
                        The credential will be received automatically.
                    </p>
                    <div class="mt-auto">
                        <div id="qr-reader" class="mb-2"></div>
                        <button type="button" id="qr-btn" class="btn btn-outline-secondary w-100"
                                onclick="toggleQrScanner('qr-reader', 'InteractionUrl', 'qr-btn', 'receive-form')">
                            <i class="fas fa-camera me-1"></i> Start Camera
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </div>
</form>

@if (Model.Result is not null)
{
    <hr class="mt-4" />

    @if (Model.Result.Success)
    {
        @if (Model.CredentialChanges is not null)
        {
            @* Credential was updated (replaced existing) *@
            <div class="alert alert-warning mt-3">
                <h5 class="alert-heading"><i class="fas fa-sync-alt me-1"></i> Credential updated</h5>
                <p class="mb-0">
                    A newer version of this credential was received. The wallet has replaced the
                    previously stored version.
                </p>
            </div>

            @if (Model.CredentialChanges.Count > 0)
            {
                <h5 class="mt-3">What changed</h5>
                <table class="table table-sm table-bordered">
                    <thead class="table-light">
                        <tr>
                            <th>Property</th>
                            <th>Previous value</th>
                            <th>New value</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var change in Model.CredentialChanges)
                        {
                            <tr>
                                <td class="font-monospace small">@change.PropertyPath</td>
                                <td class="text-danger small">@(change.OldValue ?? "(none)")</td>
                                <td class="text-success small">@(change.NewValue ?? "(none)")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted small">No leaf-property differences detected (structural changes only).</p>
            }
        }
        else
        {
            <div class="alert alert-success mt-3">
                <h5 class="alert-heading">&#10003; Credential received successfully</h5>
                <p class="mb-0">
                    The issuer completed the exchange and returned a VerifiablePresentation
                    containing your credential.
                </p>
            </div>
        }

        @if (Model.Result.VerifiablePresentationJson is not null)
        {
            <h5 class="mt-3">VerifiablePresentation</h5>
            <pre class="bg-light border rounded p-3" style="max-height:500px;overflow:auto;"><code>@Model.Result.VerifiablePresentationJson</code></pre>
        }
        else
        {
            <h5 class="mt-3">Server Message</h5>
            <pre class="bg-light border rounded p-3" style="max-height:500px;overflow:auto;"><code>@Model.Result.ServerMessageJson</code></pre>
        }
    }
    else
    {
        <div class="alert alert-danger mt-3">
            <h5 class="alert-heading">Exchange failed</h5>
            <p class="mb-0">@Model.Result.ErrorMessage</p>
        </div>
    }
}

@section Scripts {
    <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
    <script src="~/js/qr-scanner.js" asp-append-version="true"></script>
}

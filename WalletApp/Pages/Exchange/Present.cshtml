@page
@using WalletApp.Pages.Shared
@using WalletApp.Data.Models
@model PresentModel

@{
    ViewData["Title"] = "Submit Credentials";
    ViewData["ActivePage"] = NavPages.MyCredentials;
}

<h2 class="mt-3">Submit Credentials</h2>
@* ── Stage 3: Result ─────────────────────────────────────────────────────── *@
@if (Model.Result is not null)
{
    <hr class="mt-4" />

    @if (!Model.Result.Success)
    {
        <div class="alert alert-danger mt-3">
            <h5 class="alert-heading">Exchange failed</h5>
            <p class="mb-0">@Model.Result.ErrorMessage</p>
        </div>
    }
    else if (Model.Result.Verified == true)
    {
        <div class="alert alert-success mt-3">
            <h5 class="alert-heading">&#10003; Credential verified successfully</h5>
            <p class="mb-0">The verifier accepted your credential.</p>
        </div>
    }
    else
    {
        <div class="alert alert-danger mt-3">
            <h5 class="alert-heading">&#10007; Credential verification failed</h5>
            @if (Model.Result.VerifierErrors is { Length: > 0 })
            {
                <ul class="mb-0">
                    @foreach (var error in Model.Result.VerifierErrors)
                    {
                        <li>@error</li>
                    }
                </ul>
            }
        </div>
    }

    @if (Model.Result.ServerMessageJson is not null)
    {
        <h5 class="mt-3">Verifier Response</h5>
        <pre class="bg-light border rounded p-3" style="max-height:500px;overflow:auto;"><code>@Model.Result.ServerMessageJson</code></pre>
    }

    <a asp-page="/Exchange/Present" class="btn btn-secondary mt-2">Start Over</a>
}
else if (Model.InteractionStarted)
{
    @* ── Stage 2: Show matching credentials for selection ─────────────────── *@

    <p class="text-muted">
        These are the credentials that match the verifier's requirement.
        Select the credential(s) you want to send to the verifier,
        then click <strong>Present Selected Credentials</strong>.
    </p>

    <form method="post" asp-page-handler="Present">
        <input type="hidden" asp-for="InteractionUrl" />
        <input type="hidden" asp-for="ExchangeUrl" />
        <input type="hidden" asp-for="Challenge" />
        <input type="hidden" asp-for="Domain" />
        <input type="hidden" asp-for="RequiredCredentialTypesJson" />
        <input type="hidden" asp-for="RequiredAchievementTypesJson" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        @if (Model.MatchingCredentials.Count > 0)
        {
            <h5>Matching Credentials</h5>
            <div class="mb-3">
                @foreach (var cred in Model.MatchingCredentials)
                {
                    <div class="form-check mb-2">
                        <input class="form-check-input"
                               type="checkbox"
                               name="SelectedCredentialKeys"
                               id="cred_@cred.HolderCredentialKey"
                               value="@cred.HolderCredentialKey" />
                        <label class="form-check-label" for="cred_@cred.HolderCredentialKey">
                            <strong>@cred.GetCredentialName()</strong>
                            @if (cred.CredentialId is not null)
                            {
                                <span class="text-muted small ms-2">@cred.CredentialId</span>
                            }
                            <span class="text-muted small ms-2">received @cred.ReceivedAt.ToString("yyyy-MM-dd")</span>
                        </label>
                    </div>
                }
            </div>

            <button type="submit" class="btn btn-primary mb-3">Present Selected Credentials</button>
        }
        else
        {
            <div class="alert alert-warning mt-3">
                No credentials in your wallet match the verifier's requirements. Receive a matching
                credential first via <a asp-page="/Exchange/Receive">Receive Credential</a>.
            </div>
        }
    </form>

    <form method="post" asp-page-handler="Find" class="mt-2">
        <input type="hidden" asp-for="InteractionUrl" />
        <button type="submit" class="btn btn-outline-secondary btn-sm">&#8592; Back</button>
    </form>
}
else
{
    @* ── Stage 1: Collect the Interaction URL ─────────────────────────────── *@
    <p class="text-muted">
        Enter the <strong>Interaction URL</strong> from the verifying organisation, then click
        <strong>Find Matching Credentials</strong>. The wallet will contact the verifier and
        show only the credentials that satisfy its requirements.
    </p>

    <form method="post" asp-page-handler="Find">
        <div class="mb-3">
            <label asp-for="InteractionUrl" class="form-label"></label>
            <input asp-for="InteractionUrl"
                   type="url"
                   class="form-control font-monospace"
                   placeholder="https://verifier.example.com/interactions/abc123?iuv=1"
                   autofocus />
            <span asp-validation-for="InteractionUrl" class="text-danger small"></span>
            <div class="form-text">
                This URL was provided by the organisation whose site you are trying to access.
            </div>
            <partial name="_QrScannerPartial" model="@("InteractionUrl")" />
        </div>

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <button type="submit" class="btn btn-primary mt-3 mb-3">Find Matching Credentials</button>
    </form>
}

@section Scripts {
    <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
    <script src="~/js/qr-scanner.js" asp-append-version="true"></script>
}

@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using WalletApp.Data
@using WalletApp.Data.Models

@inject ApplicationDbContext _dbContext
@inject UserManager<ApplicationUser> _userManager

@if (User.Identity is { IsAuthenticated: true })
{
    var user = await _userManager.GetUserAsync(User);

    if (user != null && await _userManager.IsInRoleAsync(user, Constants.Roles.Holder))
    {
        var holders = await _dbContext.Holders
            .OrderBy(x => x.Name)
            .AsNoTracking()
            .ToListAsync();

        var selectedHolder = holders
            .SingleOrDefault(x => x.HolderKey == user.SelectedHolderKey);

        var path = $"{Context.Request.PathBase}{Context.Request.Path}";
        var query = Context.Request.QueryString;
        query = query.Add("handler", "ChangeHolder");

        <li class="nav-item">
            <div class="dropdown nav-link d-flex align-items-center gap-2">
                <i class="fa-solid fa-person" style="font-size: 1.5em"></i>
                <div class="dropdown-toggle"
                       href="#"
                       id="holderSelectorDropdown"
                       role="button"
                       data-bs-toggle="dropdown"
                       aria-haspopup="true"
                       aria-expanded="false">
                    @(selectedHolder?.Name ?? selectedHolder?.Id ?? "Select Holder")
                </div>

                <form class="dropdown-menu"
                      method="post"
                      action="@(path)@(query.ToUriComponent())"
                      aria-labelledby="holderSelectorDropdown">

                    <h6 class="dropdown-header">Holder</h6>
                    <div class="dropdown-divider"></div>

                    @foreach (var holder in holders.OrderBy(x => x.Name))
                    {
                        <button type="submit"
                                class="dropdown-item text-wrap @(selectedHolder?.HolderKey == holder.HolderKey ? "disabled" : "")"
                                name="HolderKey"
                                value="@holder.HolderKey">
                            @(holder.Name ?? holder.Id)
                        </button>
                    }
                </form>
            </div>
        </li>
    }
}
@page
@using VerifierApp.Pages.Shared
@model RequireModel

@{
    ViewData["Title"] = NavPages.HolderRequirements;
    ViewData["ActivePage"] = NavPages.HolderRequirements;
}

@if (!string.IsNullOrEmpty(ViewData["Message"]?.ToString()))
{
    <div class="alert alert-success">
        @ViewData["Message"]
    </div>
}

@if (!ModelState.IsValid)
{
    <div class="alert alert-danger">
        <div asp-validation-summary="All" class="text-danger"></div>
    </div>
}

@if (Model.InteractionUrl is null)
{   
    <h2 class="mt-3">Credential Requirements</h2>
    <p class="text-muted">
        Select a credential requirement below to start the process of submitting your
        credentials that meet the requirement.
    </p>

    <form method="post" asp-page-handler="Start">
        <div class="card shadow mb-3">
            <div class="card-header d-flex align-items-center shadow">
                <div class="card-header-icon">
                    <i class="fa-solid fa-shield-halved" style="font-size: 2em"></i>
                </div>
                <div class="text-size-large me-auto">
                    Select a Credential Requirement
                </div>
            </div>
            <div class="card-body">
                @if (Model.RequirementOptions.Count == 0)
                {
                    <p class="text-muted mb-0">No requirements have been configured yet. Please contact an administrator.</p>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var requirement in Model.RequirementOptions)
                        {
                            <button type="submit"
                                    name="SelectedRequirementKey"
                                    value="@requirement.CredentialRequirementKey"
                                    class="list-group-item list-group-item-action d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="fw-semibold">@requirement.Name</div>
                                    <div class="text-size-small">
                                        <span class="fw-bold me-2">Credential Type:</span><span class="text-muted">OpenBadgeCredential</span>
                                        <span class="fw-bold ms-2 me-2">Achievement Type:</span><span class="text-muted">@requirement.AchievementType</span>
                                        <span class="fw-bold ms-2 me-2">Reason:</span><span class="text-muted">@requirement.Reason</span>
                                    </div>
                                </div>
                                <i class="fa-solid fa-chevron-right align-self-center ms-3 text-muted"></i>
                            </button>
                        }
                    </div>
                }
            </div>
        </div>
    </form>
}
else
{
    @if (Model.CompletedExchange is not null)
    {
        var ex = Model.CompletedExchange;
        var overallPassed = ex.VerificationPassed == true;
        <div class="alert @(overallPassed ? "alert-success" : "alert-danger") mt-3">
            <h5 class="alert-heading">
                <i class="fa-solid @(overallPassed ? "fa-circle-check" : "fa-circle-xmark") me-1"></i>
                Verification @(overallPassed ? "Passed" : "Failed")
            </h5>
        </div>
        <div class="card shadow mb-3">
            <div class="card-header d-flex align-items-center shadow">
                <div class="card-header-icon">
                    <i class="fa-solid fa-list-check" style="font-size: 2em"></i>
                </div>
                <div class="text-size-large me-auto">Verification Details</div>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Proof</dt>
                    <dd class="col-sm-9">
                        @if (ex.ProofValid == true)
                        {
                            <span class="badge bg-success">Valid</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Invalid</span>
                            if (ex.VerificationFailureReason is not null)
                            {
                                <span class="text-danger ms-2">@ex.VerificationFailureReason</span>
                            }
                        }
                    </dd>

                    <dt class="col-sm-3">Credential Status</dt>
                    <dd class="col-sm-9">
                        @if (ex.StatusValid is null)
                        {
                            <span class="badge bg-secondary">Not checked (no credentialStatus)</span>
                        }
                        else if (ex.StatusValid == true)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Revoked / Invalid</span>
                            if (ex.StatusFailureReason is not null)
                            {
                                <span class="text-danger ms-2">@ex.StatusFailureReason</span>
                            }
                        }
                    </dd>

                    @if (ex.HolderDid is not null)
                    {
                        <dt class="col-sm-3">Holder DID</dt>
                        <dd class="col-sm-9 font-monospace text-break">@ex.HolderDid</dd>
                    }
                </dl>
            </div>
        </div>
        @if (ex.VerifiedCredentialJson is not null)
        {
            <div class="card shadow mb-3">
                <div class="card-header d-flex align-items-center shadow">
                    <div class="card-header-icon">
                        <i class="fa-solid fa-id-card" style="font-size: 2em"></i>
                    </div>
                    <div class="text-size-large me-auto">Verified Credential</div>
                </div>
                <div class="card-body">
                    <pre class="mb-0" style="font-size:.8em;max-height:400px;overflow-y:auto">@ex.VerifiedCredentialJson</pre>
                </div>
            </div>
        }
        <a asp-page="Require" class="btn btn-outline-secondary mt-2">
            <i class="fa-solid fa-rotate-left me-1"></i> Start New Verification
        </a>
    }
    else
    {
    <div class="card shadow mt-3 mb-3">
        <div class="card-header d-flex align-items-center shadow">
            <div class="card-header-icon">
                <i class="fa-solid fa-shield-halved" style="font-size: 2em"></i>
            </div>
            <div class="text-size-large me-auto">
                @Model.SelectedRequirement!.Name
            </div>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Credential Type</dt>
                <dd class="col-sm-9">OpenBadgeCredential</dd>

                <dt class="col-sm-3">Achievement Type</dt>
                <dd class="col-sm-9">@Model.SelectedRequirement!.AchievementType</dd>

                <dt class="col-sm-3">Reason</dt>
                <dd class="col-sm-9">@Model.SelectedRequirement.Reason</dd>
            </dl>
        </div>
    </div>

    <div class="alert alert-success">
        <h5 class="alert-heading">Interaction URL generated</h5>
        <p>
            Scan the QR code below with your wallet, or paste the URL into the
            <strong>Present Credential</strong> page in WalletApp to present your credential.
        </p>
        <div class="mb-3 d-flex justify-content-center">
            <div id="interactionQrCode"></div>
        </div>
        <div class="input-group mb-2">
            <input id="interactionUrl"
                   type="text"
                   class="form-control font-monospace"
                   value="@Model.InteractionUrl"
                   readonly />
            <button class="btn btn-outline-secondary"
                    type="button"
                    onclick="navigator.clipboard.writeText(document.getElementById('interactionUrl').value)">
                Copy
            </button>
        </div>
    </div>
    <div id="pollingStatus" class="text-muted mt-2">
        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
        Waiting for wallet to present credential…
    </div>
    }
}

@section Scripts {
    @if (Model.InteractionUrl is not null && Model.CompletedExchange is null)
    {
        <script src="~/lib/qrcodejs/qrcode.min.js"></script>
        <script>
            new QRCode(document.getElementById("interactionQrCode"), {
                text: "@Html.Raw(Model.InteractionUrl)",
                width: 128,
                height: 128,
                correctLevel: QRCode.CorrectLevel.M
            });

            (function () {
                const exchangeId = "@Model.ExchangeId";
                const pollUrl = "?handler=Result&exchangeId=" + encodeURIComponent(exchangeId);
                const interval = setInterval(async () => {
                    try {
                        const r = await fetch(pollUrl, { headers: { "Accept": "text/html" } });
                        if (r.ok) {
                            const html = await r.text();
                            // Reload when the server has a result (page will show result section)
                            if (html.includes("Verification Passed") || html.includes("Verification Failed")) {
                                clearInterval(interval);
                                window.location.href = pollUrl;
                            }
                        }
                    } catch { /* ignore network errors during polling */ }
                }, 3000);
            })();
        </script>
    }
}

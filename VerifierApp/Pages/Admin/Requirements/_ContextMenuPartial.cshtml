@using VerifierApp.Data.Models
@model CredentialRequirement

<div class="dropdown ms-auto">
    <button class="btn btn-sm text-muted" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Requirement actions menu">
        <i class="fas fa-ellipsis-v"></i>
    </button>
    <ul class="dropdown-menu dropdown-menu-end">
        <li>
            <a asp-page="/Admin/Requirements/Edit"
               asp-route-key="@Model.CredentialRequirementKey"
               class="dropdown-item">
                <i class="fas fa-edit me-1" style="width: 1em"></i>
                View / Edit
            </a>
        </li>
        <li>
            <a href="#"
               class="dropdown-item"
               data-bs-toggle="modal"
               data-bs-target="@($"#delete-requirement-{Model.CredentialRequirementKey}")">
                <i class="fas fa-trash-alt me-1" style="width: 1em"></i>
                Delete
            </a>
        </li>
    </ul>
</div>
<form method="post"
      class="modal"
      id="@($"delete-requirement-{Model.CredentialRequirementKey}")"
      tabindex="-1"
      data-ajax="true"
      data-ajax-method="post"
      data-ajax-url="?handler=DeleteRequirement&amp;key=@Model.CredentialRequirementKey"
      data-ajax-loading="#loader"
      data-ajax-success="$('#delete-requirement-@Model.CredentialRequirementKey').one('hidden.bs.modal', function(){ $('#requirement-@Model.CredentialRequirementKey').remove(); }).modal('hide');"
      data-ajax-failure="showToast(xhr.statusText)">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete @Model.Name</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>
                    Are you sure you want to delete this requirement?
                </p>
                <button type="submit" class="btn btn-sm btn-danger text-uppercase">
                    Delete
                </button>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-secondary text-uppercase" data-bs-dismiss="modal">
                    Cancel
                </button>
            </div>
        </div>
    </div>
</form>

# =============================================================================
# .gitignore for Visual Studio / .NET
# =============================================================================

# -----------------------------------------------------------------------------
# Visual Studio IDE
# -----------------------------------------------------------------------------
.vs/
.vscode/
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# -----------------------------------------------------------------------------
# Build output
# -----------------------------------------------------------------------------
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
artifacts/
BenchmarkDotNet.Artifacts/

# -----------------------------------------------------------------------------
# .NET / MSBuild
# -----------------------------------------------------------------------------
project.lock.json
project.fragment.lock.json
*.binlog

# Files built by Visual Studio
*_i.c
*_p.c
*_h.h
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.log
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc

# Visual C++ cache files
ipch/
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb

# -----------------------------------------------------------------------------
# NuGet
# -----------------------------------------------------------------------------
*.nupkg
*.nuget.props
*.nuget.targets
**/[Pp]ackages/*
!**/[Pp]ackages/build/

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
_Chutzpah*

# ATL project build results
[Dd]ebugPS/
[Rr]eleasePS/
dlldata.c

# -----------------------------------------------------------------------------
# Publishing & deployment
# -----------------------------------------------------------------------------
publish/
*.[Pp]ublish.xml
*.azurePubxml
*.pubxml
*.publishproj
PublishScripts/
csx/
*.build.csdef
ecf/
rcf/

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------
node_modules/
.ntvs_analysis.dat

# -----------------------------------------------------------------------------
# Visual Studio cache files
# -----------------------------------------------------------------------------
*.[Cc]ache
!*.[Cc]ache/

# -----------------------------------------------------------------------------
# Other tools
# -----------------------------------------------------------------------------

# JetBrains Rider
.idea/
*.sln.iml

# Paket
.paket/paket.exe
paket-files/

# FAKE - F# Make
.fake/

# CodeRush
.cr/personal

# Python
__pycache__/
*.pyc

# MFractor (Xamarin)
.mfractor/

# Local History for Visual Studio
.localhistory/

# NVidia Nsight
*.nvuser

# GhostDoc
*.GhostDoc.xml

# Telerik JustMock
*.jmconfig

# Tabs Studio
*.tss

# Miscellaneous
ClientBin/
~$*
*~
*.dbmdl
*.dbproj.schemaview
*.jfm
*.pfx
*.publishsettings
orleans.codegen.cs
Generated_Code/
FakesAssemblies/
OpenCover/
ASALocalRun/
AppPackages/
BundleArtifacts/
Package.StoreAssociation.xml
_pkginfo.txt
*.appx
StyleCopReport.xml
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm
ServiceFabricBackup/
*.rptproj.bak

# SQL Server files
*.mdf
*.ldf
*.ndf

# Business Intelligence
*.rdl.data
*.bim.layout
*.bim_*.settings
*.rptproj.rsuser

# Visual Studio 2017 auto-generated files
Generated\ Files/

# -----------------------------------------------------------------------------
# Project-specific
# -----------------------------------------------------------------------------
*.db-shm
*.db-wal
*.db
*.DotSettings
*.rsa
*.jwk
CasePackages.json
appsettings.Release.json
git-crypt.exe
*.ps1
*.csv

# NSwag generated files
**/obj/**/*.g.cs
**/OpenBadges/Generated/OpenBadgesApiClient.g.cs
**/OpenBadges/Generated/OpenBadgesModels.g.cs
**/Clr/Generated/ClrApiClient.g.cs
**/Clr/Generated/ClrModels.g.cs

# Kiota generated files - kept in source control so CI does not need kiota installed
# **/OpenBadges/Generated/
# **/Vcalm/Generated/

# Azure publish profiles (contain deployment credentials)
.publish-profiles/
